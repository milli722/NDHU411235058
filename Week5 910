class Solution {
public:
    int smallestRangeII(vector<int>& nums, int k) {
        int n = nums.size();
        sort(nums.begin(), nums.end());
        int ans = nums[n-1] - nums[0];
        int s = nums[0]+k;
        int l = nums[n-1]-k;
        
        for(int i= 0; i < n-1; i++){
            int new_max = max(l, nums[i]+k);
            int new_min = min(s, nums[i+1]-k);
            ans = min(ans, new_max - new_min);
        }
        return ans;
    }    
};
